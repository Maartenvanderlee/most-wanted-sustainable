# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local wordt NOOIT gedeeld of naar GitHub gestuurd (staat in .gitignore).
# Claude Code vertelt je bij elke stap waar je deze sleutels vindt.

# --- Supabase (stap: Opdracht 2 in BOUWPLAN.md) ---
NEXT_PUBLIC_SUPABASE_URL=            # Supabase dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # zelfde pagina > anon public key (mag in de browser)
SUPABASE_SERVICE_ROLE_KEY=           # zelfde pagina > service_role key (GEHEIM, alleen server)

# --- Reddit app (stap: Opdracht 3) ---
# Maak een gratis "script" app op https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=                    # de code direct onder de app-naam
REDDIT_CLIENT_SECRET=                # het veld "secret"

# --- YouTube Data API (stap: Opdracht 3) ---
YOUTUBE_API_KEY=                     # Google Cloud Console > APIs & Services > Credentials

# --- Admin (stap: Opdracht 4) ---
ADMIN_PASSWORD=                      # verzin zelf een sterk wachtwoord voor de /admin pagina

# --- Publieke site-URL (stap: Opdracht 4/5) ---
NEXT_PUBLIC_SITE_URL=                # bv. https://mostwanted.nl (voor sitemap.xml en robots.txt); leeg = localhost

# --- Pipeline (stap: Opdracht 5) ---
CRON_SECRET=                         # verzin een lange willekeurige tekst; beveiligt de dagelijkse cron

# --- Productfoto's (optioneel) ---
PEXELS_API_KEY=                      # gratis sleutel via https://www.pexels.com/api/ (voor "Foto's automatisch invullen" in de admin)
